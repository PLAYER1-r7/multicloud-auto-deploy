# Multi-Cloud Cost Monitor — 設定ファイル
# このファイルをコピーして .env に名前を変えて値を記入してください
#   cp cost-monitor.env.sample .env
#
# .env は git に含まれません (.gitignore 済み)。

# ── AWS ──────────────────────────────────────────────────────
# aws configure 済みの場合は不要 (デフォルトプロファイルを使用)
# 特定プロファイルを使いたい場合は指定
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-northeast-1

# ── Azure ─────────────────────────────────────────────────────
# az login 済みの状態で使用
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── GCP ───────────────────────────────────────────────────────
# gcloud auth login 済みの状態で使用
# Cloud Console > Billing > billing account ID (例: 012345-ABCDEF-GHIJKL)
GCP_BILLING_ACCOUNT=012345-ABCDEF-GHIJKL
GCP_PROJECT_ID=your-gcp-project-id

# ── GitHub ────────────────────────────────────────────────────
# https://github.com/settings/tokens で read:org スコープ付きトークンを発行
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Organization billing を取得する場合
GH_ORG=PLAYER1-r7
# リポジトリ単位で取得する場合 (GH_ORG が優先される)
# GH_REPO=PLAYER1-r7/multicloud-auto-deploy
