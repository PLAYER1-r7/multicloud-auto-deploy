FROM python:3.12-slim

WORKDIR /workspace

# Install dependencies
COPY requirements-gcp.txt .
RUN pip install --no-cache-dir -r requirements-gcp.txt

# Copy application code
COPY app/ app/
COPY function_gcp_wrapper.py main.py

# Cloud Run requires listening on port 8080
ENV PORT=8080

# Use Gunicorn with correct ASGI worker
CMD exec gunicorn --bind :${PORT} --workers 1 --worker-class uvicorn.workers.UvicornWorker --timeout 0 main:app
