# Azure production — committed static config (single source of truth)
# These values are stable and do NOT depend on Pulumi runtime state.
# This file is intentionally NOT gitignored so CI can read it reliably.
# Update if Azure AD app registration is changed or domain changes.

CLOUD_CUSTOM_DOMAIN="www.azure.ashnova.jp"
# Azure AD app registration — production (created once, rarely changes)
# Retry deployment: fix azure frontdoor conflict (409 Conflict)
CLOUD_AZURE_CLIENT_ID="0b926ff6-fc03-4c9c-a359-96964ef15941"
CLOUD_AZURE_TENANT_ID="a3182bec-d835-4ce3-af06-04579abf597e"
# Function App name follows naming convention: multicloud-auto-deploy-<stack>-func
CLOUD_FUNCTION_APP_NAME="multicloud-auto-deploy-production-func"
# Front Door profile name
CLOUD_FRONTDOOR_PROFILE="multicloud-auto-deploy-production-fd"
