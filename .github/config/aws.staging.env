# AWS staging — committed static config (single source of truth)
# Dynamic values (Cognito IDs, bucket names, distribution IDs) come from Pulumi outputs.
# This file is intentionally NOT gitignored so CI can read it reliably.
# 【テスト】このファイルの変更はAWSワークフローのみをトリガーします

CLOUD_CUSTOM_DOMAIN="staging.aws.ashnova.jp"
# ACM CERT: 930c5663-c65e-4d06-b01f-76b6094a2d06 (PENDING_VALIDATION as of 2026-03-01)
# DNS validation CNAME record needed in ashnova.jp zone:
#   Name:  _a582939c3edf765df0da9fff64cc2ddb.staging.aws.ashnova.jp.
#   Value: _1996108ffa25cd66ebe500d3450b6907.jkddzztszm.acm-validations.aws.
# Once ISSUED, set: CLOUD_ACM_CERT_ARN="arn:aws:acm:us-east-1:278280499340:certificate/930c5663-c65e-4d06-b01f-76b6094a2d06"
CLOUD_ACM_CERT_ARN=""
# CloudFront origin hostname — fill in from: pulumi stack output cloudfront_domain (staging stack)
CLOUD_CLOUDFRONT_DOMAIN="d1tf3uumcm4bo1.cloudfront.net"
# CloudFront distribution ID — fill in from: pulumi stack output cloudfront_distribution_id (staging stack)
CLOUD_CLOUDFRONT_DISTRIBUTION_ID=""
