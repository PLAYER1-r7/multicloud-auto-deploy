# Azure staging — committed static config (single source of truth)
# These values are stable and do NOT depend on Pulumi runtime state.
# This file is intentionally NOT gitignored so CI can read it reliably.
# Update if Azure AD app registration is changed or domain changes.

# staging は独自ドメイン・CDN (Azure Front Door) を使用しない
# Blob Storage 静的ウェブサイトホスティングを直接使用
CLOUD_CUSTOM_DOMAIN=""
# Azure AD app registration — staging (created once, rarely changes)
CLOUD_AZURE_CLIENT_ID="03a168ac-7de3-4e5c-8fb1-99fa6dcbfe77"
CLOUD_AZURE_TENANT_ID="a3182bec-d835-4ce3-af06-04579abf597e"
# Function App name follows naming convention: multicloud-auto-deploy-<stack>-func
CLOUD_FUNCTION_APP_NAME="multicloud-auto-deploy-staging-func"
# Front Door profile: staging では不使用
CLOUD_FRONTDOOR_PROFILE=""
